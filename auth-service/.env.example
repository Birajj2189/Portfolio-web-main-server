# Server
NODE_ENV=development
PORT=3001

# Database (PostgreSQL)
# Local: postgresql://user:password@localhost:5432/dbname?schema=public
# Docker: postgresql://user:password@postgres:5432/dbname?schema=public
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5434/portfolio_auth?schema=public

# JWT Secrets — generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
ACCESS_TOKEN_SECRET=your_access_token_secret_min_32_chars
REFRESH_TOKEN_SECRET=your_refresh_token_secret_min_32_chars
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Cookie signing secret
COOKIE_SECRET=your_cookie_secret_min_32_chars

# CORS — your frontend URL
CLIENT_URL=http://localhost:3000

# Admin seed (used by: npm run db:seed)
ADMIN_EMAIL=admin@portfolio.com
ADMIN_PASSWORD=Admin@123!
